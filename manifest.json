{
  "manifest_version": 3,
  "name": "PolyRatings Extension",
  "version": "0.1.0",
  "description": "Integrates PolyRatings.dev scores directly into the Cal Poly Schedule Builder.",
  "icons": {
    "16":  "icons/icon.png",
    "48":  "icons/icon.png",
    "128": "icons/icon.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://cmsweb.pscs.calpoly.edu/*"],
      "js": [
        "constants.js",
        "utils.js",
        "styles.js",
        "tooltips.js",
        "rating-ui.js",
        "agent.js",
        "professor-processor.js",
        "observers.js",
        "content.js"
      ],
      "all_frames": true
    }
  ],
  "permissions": ["storage"],
  "host_permissions": ["https://cmsweb.pscs.calpoly.edu/*"]
}